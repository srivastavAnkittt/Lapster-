/* End Elza font */


h1,
h2,
h3,
h4,
h5,
h6,
.h0,
.h1,
.h2,
.h3,
.h4,
.h5,
.h6 {
	font-family: 'Vinila Condensed Test' !important;
}

body,
p,
span,
a,
button,
input,
textarea,
select,
label,
li,
ul,
ol {
	font-family: 'Elza Trial' !important;
}

:root {
	--font-heading-family: 'Vinila Condensed Test';
	--font-body-family: 'Elza Trial';
}