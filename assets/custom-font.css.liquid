@font-face {
    font-family: 'Vinila Condensed Test';
    src: url('{{ "VinilaCondensed-Regular.woff2" | asset_url }}') format('woff2'),
         url('{{ "VinilaCondensed-Regular.woff" | asset_url }}') format('woff');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
}

@font-face {
    font-family: 'Vinila Condensed Test';
    src: url('{{ "VinilaCondensed-Black.woff2" | asset_url }}') format('woff2'),
         url('{{ "VinilaCondensed-Black.woff" | asset_url }}') format('woff');
    font-weight: 900;
    font-style: normal;
    font-display: swap;
}

@font-face {
    font-family: 'Vinila Condensed Test';
    src: url('{{ "VinilaCondensed-Bold.woff2" | asset_url }}') format('woff2'),
         url('{{ "VinilaCondensed-Bold.woff" | asset_url }}') format('woff');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
}

@font-face {
    font-family: 'Vinila Condensed Test';
    src: url('{{ "VinilaCondensed-ExtraBold.woff2" | asset_url }}') format('woff2'),
         url('{{ "VinilaCondensed-ExtraBold.woff" | asset_url }}') format('woff');
    font-weight: 800;
    font-style: normal;
    font-display: swap;
}

@font-face {
    font-family: 'Vinila Condensed Test';
    src: url('{{ "VinilaCondensed-Light.woff2" | asset_url }}') format('woff2'),
         url('{{ "VinilaCondensed-Light.woff" | asset_url }}') format('woff');
    font-weight: 300;
    font-style: normal;
    font-display: swap;
}



h1,
h2,
h3,
h4,
h5,
h6,
.h0,
.h1,
.h2,
.h3,
.h4,
.h5,
.h6 {
	font-family: 'Vinila Condensed Test' !important;
}

body,
p,
span,
a,
button,
input,
textarea,
select,
label,
li,
ul,
ol {
	font-family: 'Elza' !important;
}

:root {
	--font-heading-family: 'Vinila Condensed Test';
	--font-body-family: 'Elza';
}